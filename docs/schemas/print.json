{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://platecli.local/schemas/print.json",
  "title": "platecli print success or confirmation envelope",
  "type": "object",
  "required": ["status", "command", "file"],
  "properties": {
    "status": {"type": "string"},
    "command": {"const": "print"},
    "file": {"type": "string"},
    "printed": {"type": "boolean"},
    "dry_run": {"type": "boolean"},
    "next_command": {"type": "array"}
  },
  "additionalProperties": true
}
