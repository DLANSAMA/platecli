[run]
branch = True
source = bambu_cli

[report]
precision = 1
# Honest coverage: do not hide except Exception/pass/continue.
# Only exclude lines that are definitionally unmeasurable or non-executable.
exclude_lines =
    pragma: no cover
    def __repr__
    if TYPE_CHECKING:
    raise NotImplementedError
    if __name__ == .__main__.:
    \.\.\.
